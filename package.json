{
  "name": "figmagent",
  "description": "Figmagent - AI Agent to Figma MCP",
  "version": "0.3.3",
  "type": "module",
  "scripts": {
    "socket": "bun run src/socket.ts",
    "setup": "./scripts/setup.sh",
    "test": "bun test",
    "lint": "bunx biome lint src tests",
    "lint:fix": "bunx biome check --write src tests",
    "format": "bunx biome format --write src tests",
    "check": "bunx biome check src tests",
    "build:plugin": "bun run src/figma_plugin/build.js",
    "transcribe": "claude-code-transcripts all -s ~/.claude/projects/-Users-davidbowman-Github-cursor-talk-to-figma-mcp -o ~/Github/cursor-talk-to-figma-mcp/.claude/transcripts --include-agents",
    "extract-sessions": "bun scripts/extract-sessions.ts",
    "refresh-manifest": "bun scripts/refresh-manifest.ts",
    "sync-issues": "bun scripts/sync-tracker-issues.ts",
    "auto-improve": "bash scripts/auto-improve.sh"
  },
  "devDependencies": { 
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "uuid": "latest",
    "ws": "latest",
    "zod": "^3.25.76"
  }
}
